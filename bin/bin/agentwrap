#!/usr/bin/bash
set -euo pipefail

EXTRA_RW_DIR=(
    "$HOME/.cache/opencode"
    "$HOME/.local/share/opencode"
    "$HOME/.local/state/opencode"
    "$HOME/.config/opencode"
)
EXTRA_RO_DIR=(
    "$HOME/.npm-global"
    "$HOME/.local/share/pipx"
    "$HOME/.dotfiles/opencode"
    "$HOME/.config/pylintrc"
    "$HOME/.config/black"
    "$HOME/git"
)
PASSTHROUGH_ENV_VARS=(
    HOME
    USER
    LOGNAME
    SHELL
    COLORTERM
    TERM
    TERMINFO
    TERM_PROGRAM
    TERM_PROGRAM_VERSION
    LANG
)
BWRAP_PATH="$HOME/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:$HOME/.npm-global/bin"

if [[ -z ${1:-} ]]; then
    echo "ERROR: missing command to agentwrap" >&2
    exit 1
fi

# Workout the workspace we are in for binding
repo="$(git -C "$PWD" rev-parse --show-toplevel 2>/dev/null || true)"
if [[ -n ${repo:-} ]]; then
    workspace="$repo"
else
    workspace="$PWD"
fi

BINDS_EXTRA_RW_DIR=()
for dir in "${EXTRA_RW_DIR[@]}"; do
    if [ -d "$dir" ]; then
        BINDS_EXTRA_RW_DIR+=(--bind-try "$dir" "$dir")
    fi
done

BINDS_EXTRA_RO_DIR=()
for dir in "${EXTRA_RO_DIR[@]}"; do
    if [ -d "$dir" ]; then
        BINDS_EXTRA_RO_DIR+=(--ro-bind-try "$dir" "$dir")
    fi
done

ENV_VARS=()
for var in "${PASSTHROUGH_ENV_VARS[@]}"; do
    if [[ -n "${!var+set}" ]]; then
        ENV_VARS+=(--setenv "$var" "${!var}")
    fi
done

# Execute agent in bubblewrap sandbox
exec bwrap \
    --unshare-all \
    --share-net \
    --die-with-parent \
    --new-session \
    --clearenv \
    \
    `# Basic filesystem structure` \
    --ro-bind /usr /usr \
    --ro-bind /lib /lib \
    --ro-bind /lib64 /lib64 \
    --ro-bind /bin /bin \
    --ro-bind /sbin /sbin \
    --proc /proc \
    --dev /dev \
    --tmpfs /tmp \
    --tmpfs /run \
    \
    `# Minimal /etc files needed` \
    --ro-bind /etc/resolv.conf /etc/resolv.conf \
    --ro-bind /etc/hosts /etc/hosts \
    --ro-bind /etc/nsswitch.conf /etc/nsswitch.conf \
    --ro-bind /etc/passwd /etc/passwd \
    --ro-bind /etc/group /etc/group \
    --ro-bind /etc/localtime /etc/localtime \
    \
    `# SSL certificates for API access` \
    --ro-bind-try /etc/ssl /etc/ssl \
    --ro-bind-try /etc/ca-certificates /etc/ca-certificates \
    \
    "${BINDS_EXTRA_RO_DIR[@]}" \
    "${BINDS_EXTRA_RW_DIR[@]}" \
    \
    `# Terminal and environment` \
    --dir "$HOME" \
    --chdir "$PWD" \
    "${ENV_VARS[@]}" \
    --setenv TMPDIR /tmp \
    --setenv PATH "$BWRAP_PATH" \
    \
    `# Bind in git-repo/pwd as rw` \
    --bind "$workspace" "$workspace" \
    \
    "$@"
