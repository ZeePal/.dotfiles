{
    "$schema": "https://opencode.ai/config.json",
    "share": "disabled",
    "model": "github-copilot/gpt-5-mini",
    "small_model": "github-copilot/gpt-5-mini",
    "formatter": {
        "black": {
            "command": [
                "black",
                "--line-length",
                "120",
                "$FILE"
            ],
            "extensions": [
                ".py",
                ".pyi"
            ]
        }
    },
    "mcp": {
        "context7": {
            "type": "remote",
            "url": "https://mcp.context7.com/mcp"
        }
    }
}
