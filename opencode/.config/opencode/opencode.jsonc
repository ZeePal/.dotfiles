{
    "$schema": "https://opencode.ai/config.json",
    "share": "disabled",
    "model": "github-copilot/gpt-5.4",
    "small_model": "github-copilot/gpt-5-mini",
    "lsp": false,
    "tools": {
        "lsp": false,
        "webfetch": false,
        "todowrite": false,
        "question": false,
        "quota_status": false
    },
    "plugin": [
        "@slkiser/opencode-quota"
    ],
    "formatter": {
        "black": {
            "command": [
                "black",
                "--line-length",
                "120",
                "$FILE"
            ],
            "extensions": [
                ".py",
                ".pyi"
            ]
        }
    },
    "experimental": {
        "quotaToast": {
            "enabledProviders": [
                "openai",
                "copilot"
            ]
        }
    }
}
